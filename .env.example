# D1 Staff Audit — Environment Variables
# Copy this file to .env and fill in your values

# Server
PORT=3001
NODE_ENV=development

# Database — for Railway, set this to the mounted volume path, e.g. /data/db.sqlite
DATABASE_PATH=./data/db.sqlite

# Resend Email API (https://resend.com)
RESEND_API_KEY=re_your_key_here
FROM_EMAIL=D1 Staff Audit <audit@yourdomain.com>

# Notification recipients
NOTIFY_EMAIL_1=austin@youremail.com
NOTIFY_EMAIL_2=carly@youremail.com

# App public URL (used in notification email links)
APP_URL=https://your-app.railway.app
